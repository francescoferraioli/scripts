#!/usr/bin/env bash
set -euo pipefail

if [[ $# -eq 0 ]]; then
  echo "usage: ff devbox run <devbox>|all [<devbox>|all...] -- <command...>" >&2
  exit 1
fi

devboxes=()
while [[ $# -gt 0 && "$1" != "--" ]]; do
  if [[ "$1" == "all" ]]; then
    read -r -a all_devboxes <<< "$(ff devbox all)"
    devboxes+=("${all_devboxes[@]}")
  else
    devboxes+=("$1")
  fi
  shift
done

if [[ ${#devboxes[@]} -eq 0 ]]; then
  echo "error: at least one devbox name is required" >&2
  echo "usage: ff devbox run <devbox>|all [<devbox>|all...] -- <command...>" >&2
  exit 1
fi

if [[ $# -eq 0 ]]; then
  echo "error: missing -- before command" >&2
  echo "usage: ff devbox run <devbox>|all [<devbox>|all...] -- <command...>" >&2
  exit 1
fi

shift

if [[ $# -eq 0 ]]; then
  echo "error: missing command after --" >&2
  exit 1
fi

remote_script() {
  if [[ $# -eq 1 ]]; then
    # One quoted string: run as shell (supports &&, ||, pipes, etc.)
    printf 'export PATH="$HOME/scripts:$PATH"; exec </dev/null; %s' "$1"
  else
    local cmd
    cmd=$(printf ' %q' "$@")
    printf 'export PATH="$HOME/scripts:$PATH"; exec </dev/null; %s' "${cmd:1}"
  fi
}

for devbox in "${devboxes[@]}"; do
  script=$(remote_script "$@")
  ssh -o BatchMode=yes -o ConnectTimeout=300 \
    -o ClearAllForwardings=yes -o PermitLocalCommand=no \
    "coder.frankief/$devbox" \
    bash -lc "$(printf '%q' "$script")" &
done
wait
