#!/usr/bin/env bash
set -euo pipefail

if [[ $# -eq 0 ]]; then
  echo "usage: ff devbox ff <devbox> [<devbox>...] -- <ff-object> [<ff-action> [<ff-args...>]]" >&2
  exit 1
fi

devboxes=()
while [[ $# -gt 0 && "$1" != "--" ]]; do
  devboxes+=("$1")
  shift
done

if [[ ${#devboxes[@]} -eq 0 ]]; then
  echo "error: at least one devbox name is required" >&2
  echo "usage: ff devbox ff <devbox> [<devbox>...] -- <ff-object> [<ff-action> [<ff-args...>]]" >&2
  exit 1
fi

if [[ $# -eq 0 ]]; then
  echo "error: missing -- before ff arguments" >&2
  echo "usage: ff devbox ff <devbox> [<devbox>...] -- <ff-object> [<ff-action> [<ff-args...>]]" >&2
  exit 1
fi

shift

if [[ $# -eq 0 ]]; then
  echo "error: missing ff arguments after --" >&2
  exit 1
fi

ff_args=$(printf ' %q' "$@")
ff_args=${ff_args:1}

ff devbox run "${devboxes[@]}" -- bash -lc "\$HOME/scripts/ff ${ff_args}"
