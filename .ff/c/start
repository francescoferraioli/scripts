#!/usr/bin/env bash
env="${1:-staging}"
[[ $# -ge 1 ]] && shift

# Optional flags before -e entries: sm → source maps, t → infra highway tunnel
optional_args=()
while [[ "${1:-}" == "sm" || "${1:-}" == "t" ]]; do
  case "$1" in
    sm) optional_args+=(-s true) ;;
    t) optional_args+=(-t enabled) ;;
  esac
  shift
done

# Build -e args from remaining params (default to editor if none)
extra_es=("${@:-editor}")

if [[ ${#extra_es[@]} -gt 1 ]]; then
  export MULTI_COMPILER=true
fi

e_args=()
for e in "${extra_es[@]}"; do
  e_args+=(-e "$e")
done

cd ~/work/canva/web
pnpm webpack-dev-server -p "$env" "${optional_args[@]}" "${e_args[@]}"
