#!/usr/bin/env python3
"""Extract speaker notes from a PowerPoint (.pptx) file."""

from __future__ import annotations

import argparse
import re
import sys
import zipfile
from pathlib import Path
from xml.etree import ElementTree as ET

DRAWING_NS = "http://schemas.openxmlformats.org/drawingml/2006/main"
A_P = f"{{{DRAWING_NS}}}p"
A_T = f"{{{DRAWING_NS}}}t"

NOTES_SLIDE_RE = re.compile(r"ppt/notesSlides/notesSlide(\d+)\.xml$", re.IGNORECASE)


def latest_downloaded_pptx(downloads_dir: Path | None = None) -> Path:
    folder = downloads_dir or (Path.home() / "Downloads")
    if not folder.is_dir():
        print(f"ERROR: Downloads folder not found: {folder}", file=sys.stderr)
        sys.exit(1)

    candidates = [
        *folder.glob("*.pptx"),
        *folder.glob("*.PPTX"),
    ]
    if not candidates:
        print(f"ERROR: No .pptx files in {folder}", file=sys.stderr)
        sys.exit(1)

    return max(candidates, key=lambda path: path.stat().st_mtime)


def paragraph_text(paragraph: ET.Element) -> str:
    parts: list[str] = []
    for node in paragraph.iter(A_T):
        if node.text:
            parts.append(node.text)
    return "".join(parts)


def notes_text_from_xml(xml_bytes: bytes) -> str:
    root = ET.fromstring(xml_bytes)
    paragraphs = [paragraph_text(p) for p in root.iter(A_P)]
    paragraphs = [p for p in paragraphs if p.strip()]
    return "\n".join(paragraphs)


def extract_speaker_notes(pptx_path: Path) -> list[tuple[int, str]]:
    if not pptx_path.is_file():
        print(f"ERROR: File not found: {pptx_path}", file=sys.stderr)
        sys.exit(1)

    if pptx_path.suffix.lower() != ".pptx":
        print(f"ERROR: Expected a .pptx file: {pptx_path}", file=sys.stderr)
        sys.exit(1)

    slides: list[tuple[int, str]] = []

    try:
        with zipfile.ZipFile(pptx_path) as archive:
            for name in archive.namelist():
                match = NOTES_SLIDE_RE.match(name)
                if not match:
                    continue
                slide_number = int(match.group(1))
                xml_bytes = archive.read(name)
                text = notes_text_from_xml(xml_bytes).strip()
                if text:
                    slides.append((slide_number, text))
    except zipfile.BadZipFile:
        print(f"ERROR: Not a valid .pptx (zip) file: {pptx_path}", file=sys.stderr)
        sys.exit(1)

    slides.sort(key=lambda item: item[0])
    return slides


def format_notes(slides: list[tuple[int, str]]) -> str:
    if not slides:
        return ""

    blocks = []
    for slide_number, text in slides:
        blocks.append(f"--- Slide {slide_number} ---\n{text}")
    return "\n\n".join(blocks)


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Extract speaker notes from a .pptx file.",
    )
    parser.add_argument(
        "path",
        nargs="?",
        help="Path to the .pptx file (default: most recent .pptx in ~/Downloads)",
    )
    parser.add_argument(
        "-o",
        "--output",
        metavar="FILE",
        help="Write notes to this file instead of stdout",
    )
    parser.add_argument(
        "--downloads-dir",
        metavar="DIR",
        help="Folder to search for the latest .pptx when path is omitted (default: ~/Downloads)",
    )
    return parser.parse_args(argv)


def main(argv: list[str] | None = None) -> None:
    args = parse_args(argv or sys.argv[1:])

    if args.path:
        pptx_path = Path(args.path).expanduser().resolve()
    else:
        downloads = (
            Path(args.downloads_dir).expanduser()
            if args.downloads_dir
            else None
        )
        pptx_path = latest_downloaded_pptx(downloads)
        print(f"Using: {pptx_path}", file=sys.stderr)

    slides = extract_speaker_notes(pptx_path)
    output = format_notes(slides)

    if not output:
        print(f"No speaker notes found in {pptx_path}", file=sys.stderr)
        sys.exit(0)

    if args.output:
        out_path = Path(args.output).expanduser()
        out_path.write_text(output + "\n", encoding="utf-8")
        print(f"Wrote notes for {len(slides)} slide(s) to {out_path}", file=sys.stderr)
    else:
        print(output)


if __name__ == "__main__":
    main()
